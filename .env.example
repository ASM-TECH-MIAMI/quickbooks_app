# QuickBooks OAuth app credentials (developer.intuit.com)
QB_CLIENT_ID=your_intuit_client_id
QB_CLIENT_SECRET=your_intuit_client_secret

# Anthropic API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (app.supabase.com)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:5432/postgres

# Set to your Cloudflare tunnel domain in production
APP_BASE_URL=http://localhost:8000
